---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import Footer from "../../components/Footer.astro";
import { posts } from "../../data/posts";
import { site } from "../../data/site";

const sorted = [...posts].sort((a, b) => b.published.localeCompare(a.published));
---

<BaseLayout
  title="Writing · Aasim Sani"
  description="Essays on engineering, startups, and how teams actually ship."
  ogType="website"
  ogTitle="Writing · Aasim Sani"
  canonical={`${site.url}blog/`}
>
  <ThemeToggle />
  <main class="blog-index">
    <header>
      <a class="home-link" href="/">&larr; aasimsani.net</a>
      <h1>Writing</h1>
      <p class="tagline">Essays on engineering, startups, and how teams actually ship.</p>
    </header>
    <ul class="post-list">
      {sorted.map((post) => (
        <li>
          <a class="post-card" href={`/blog/${post.slug}/`}>
            <div class="post-meta">
              <span>{post.displayDate}</span>
              <span aria-hidden="true">·</span>
              <span>{post.readingTime}</span>
            </div>
            <h2>{post.title}</h2>
            <p class="post-desc">{post.description}</p>
            <span class="read-more">Read the essay &rarr;</span>
          </a>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</BaseLayout>

<style>
  .blog-index {
    max-width: 720px;
    margin: 0 auto;
    padding: 6rem 1.5rem 5rem;
    min-height: 70vh;
  }
  .home-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-stone);
    text-decoration: none;
  }
  .home-link:hover {
    color: var(--color-terracotta);
  }
  h1 {
    font-size: clamp(2.4rem, 6vw, 3.4rem);
    margin: 1.2rem 0 0.4rem;
  }
  .tagline {
    color: var(--color-ink-soft);
    margin-bottom: 3.5rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .post-card {
    display: block;
    padding: 1.8rem;
    border: 1px solid var(--color-fog);
    border-radius: 0.75rem;
    background: var(--color-cream-soft);
    text-decoration: none;
    color: var(--color-ink);
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .post-card:hover {
    color: var(--color-ink);
    border-color: color-mix(in srgb, var(--color-terracotta) 45%, var(--color-fog));
    transform: translateY(-2px);
    box-shadow: 0 10px 24px -18px rgba(0, 0, 0, 0.45);
  }
  .post-meta {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-stone);
    margin-bottom: 0.6rem;
  }
  .post-card h2 {
    font-size: 1.6rem;
    line-height: 1.25;
    margin: 0 0 0.6rem;
  }
  .post-desc {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    margin-bottom: 0.9rem;
  }
  .read-more {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-terracotta);
  }
</style>
