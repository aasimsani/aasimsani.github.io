<script>
  // Reading progress bar
  const bar = document.querySelector<HTMLElement>(".read-progress span");
  function paintProgress() {
    if (!bar) return;
    const doc = document.documentElement;
    const max = doc.scrollHeight - window.innerHeight;
    bar.style.width = `${max > 0 ? (window.scrollY / max) * 100 : 0}%`;
  }
  window.addEventListener("scroll", paintProgress, { passive: true });
  paintProgress();

  // Attention-load slider
  const slider = document.getElementById("loadSlider") as HTMLInputElement | null;
  const codePanel = document.getElementById("loadCode");
  const readout = document.getElementById("loadReadout");
  slider?.addEventListener("input", () => {
    const v = Number(slider.value);
    codePanel?.style.setProperty("--load", String(v / 100));
    if (readout) readout.textContent = `${v}%`;
  });

  // Checklist persistence (survives reload)
  const CHECK_KEY = "ib-post-rituals.v1";
  const boxes = document.querySelectorAll<HTMLInputElement>("#ritualChecklist input[type=checkbox]");
  try {
    const saved = JSON.parse(localStorage.getItem(CHECK_KEY) ?? "{}");
    boxes.forEach((b) => { if (saved[b.dataset.key!]) b.checked = true; });
  } catch { /* ignore */ }
  boxes.forEach((b) =>
    b.addEventListener("change", () => {
      const state: Record<string, boolean> = {};
      boxes.forEach((x) => { state[x.dataset.key!] = x.checked; });
      try { localStorage.setItem(CHECK_KEY, JSON.stringify(state)); } catch { /* ignore */ }
    })
  );

  // Copy checklist as markdown
  function flashCopied(btn: HTMLElement, label: string) {
    const prev = btn.textContent;
    btn.textContent = label;
    setTimeout(() => { btn.textContent = prev; }, 1400);
  }
  async function copyText(text: string, btn: HTMLElement) {
    try {
      await navigator.clipboard.writeText(text);
      flashCopied(btn, "Copied ✓");
    } catch {
      flashCopied(btn, "Copy failed");
    }
  }
  document.getElementById("copyChecklist")?.addEventListener("click", (e) => {
    const md = [
      "## Relentless alignment — the rhythm",
      "",
      "- [ ] Write what \"done\" means — one paragraph, before code. The standard holder edits it.",
      "- [ ] Show the ugly version at 30%. Mid-flight demos on the real thing, not slides.",
      "- [ ] Review for the unintended, not just the incorrect. \"What else does this change?\"",
      "- [ ] Alert on absence, not just errors. Silence is a failure mode.",
      "- [ ] Root-cause with the attention question: what were we staring at, and who was positioned to see it?",
      "- [ ] Fix the pattern, not the instance.",
      "",
      `(from ${location.origin}/blog/inattentional-blindness/)`,
    ].join("\n");
    copyText(md, e.currentTarget as HTMLElement);
  });

  // Copy link
  document.getElementById("copyLink")?.addEventListener("click", (e) => {
    const btn = e.currentTarget as HTMLElement;
    copyText(btn.dataset.url ?? location.href, btn);
  });
</script>
