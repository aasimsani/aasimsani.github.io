---
import { research } from "../data/research";
import SectionHeader from "./SectionHeader.astro";
---

<section class="research section-anchor" id="research">
  <div class="container">
    <SectionHeader title="Research" glyph="book" />
    <div class="entries">
      {research.map((r) => (
        <article class="entry">
          <div class="logo-mark" data-mat={r.mat}>
            {r.link ? (
              <a href={r.link}><img src={r.logo} alt={r.title} /></a>
            ) : (
              <img src={r.logo} alt={r.title} />
            )}
          </div>
          <div class="body">
            <h3>{r.title}</h3>
            {r.link && r.linkLabel && (
              <h5 class="link"><a href={r.link}>{r.linkLabel}</a></h5>
            )}
            {r.paragraphs.map((p) => <p>{p}</p>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .research {
    padding: 5rem 1.5rem;
    background: var(--color-cream);
  }
  .container {
    max-width: 760px;
    margin: 0 auto;
  }
  .entries {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .entry {
    display: grid;
    grid-template-columns: 108px 1fr;
    gap: 1.75rem;
    align-items: start;
  }
  @media (max-width: 600px) {
    .entry { grid-template-columns: 1fr; }
  }
  h3 {
    font-size: 1.4rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
  }
  h5.link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 400;
    margin: 0 0 1rem;
  }
  p {
    font-size: 1.05rem;
    margin: 0.5rem 0;
  }
</style>
