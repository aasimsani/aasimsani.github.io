---
// Interactive "woven light" particle field for the hero. A Three.js point-cloud
// torus-knot, recolored to the site palette (terracotta / sage / stone on cream)
// and theme-aware. Vanilla Three.js — no React. Mounts behind the hero overlay
// and fills .home.
---

<div class="woven-bg" aria-hidden="true"></div>

<style>
  .woven-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none; /* hero content stays interactive; we read mouse globally */
  }
  .woven-bg :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import * as THREE from "three";

  const mount = document.querySelector<HTMLElement>(".woven-bg");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (mount) {
    // --- palette pulled live from CSS custom properties (theme-aware) ---
    const readPalette = () => {
      const cs = getComputedStyle(document.documentElement);
      const get = (name: string) => cs.getPropertyValue(name).trim() || "#c46a4d";
      return [get("--color-terracotta"), get("--color-sage"), get("--color-stone")].map(
        (hex) => new THREE.Color(hex)
      );
    };

    const PARTICLE_COUNT = 6000;
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(
      75,
      mount.clientWidth / Math.max(mount.clientHeight, 1),
      0.1,
      1000
    );
    camera.position.z = 5;

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setClearColor(0x000000, 0); // transparent: cream .home bg shows through
    renderer.setSize(mount.clientWidth, mount.clientHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    mount.appendChild(renderer.domElement);

    const positions = new Float32Array(PARTICLE_COUNT * 3);
    const original = new Float32Array(PARTICLE_COUNT * 3);
    const velocities = new Float32Array(PARTICLE_COUNT * 3);
    const colors = new Float32Array(PARTICLE_COUNT * 3);

    const knot = new THREE.TorusKnotGeometry(1.5, 0.5, 220, 32);
    const knotCount = knot.attributes.position.count;

    const paintColors = () => {
      const palette = readPalette();
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const c = palette[i % palette.length];
        const j = 0.85 + Math.random() * 0.3; // subtle lightness jitter
        colors[i * 3] = Math.min(c.r * j, 1);
        colors[i * 3 + 1] = Math.min(c.g * j, 1);
        colors[i * 3 + 2] = Math.min(c.b * j, 1);
      }
      geometry.attributes.color.needsUpdate = true;
    };

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      const v = i % knotCount;
      const x = knot.attributes.position.getX(v);
      const y = knot.attributes.position.getY(v);
      const z = knot.attributes.position.getZ(v);
      positions[i * 3] = original[i * 3] = x;
      positions[i * 3 + 1] = original[i * 3 + 1] = y;
      positions[i * 3 + 2] = original[i * 3 + 2] = z;
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute("color", new THREE.BufferAttribute(colors, 3));
    paintColors();

    const material = new THREE.PointsMaterial({
      size: 0.025,
      vertexColors: true,
      transparent: true,
      opacity: 0.85,
      blending: THREE.NormalBlending,
      depthWrite: false,
    });
    const points = new THREE.Points(geometry, material);
    scene.add(points);

    // --- mouse (global; canvas is pointer-events:none) ---
    const mouse = new THREE.Vector2(0, 0);
    const onMouseMove = (e: MouseEvent) => {
      mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
      mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
    };

    const clock = new THREE.Clock();

    const renderFrame = () => {
      const t = clock.getElapsedTime();
      const mx = mouse.x * 3;
      const my = mouse.y * 3;
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        const ix = i * 3,
          iy = i * 3 + 1,
          iz = i * 3 + 2;
        let px = positions[ix],
          py = positions[iy],
          pz = positions[iz];
        let vx = velocities[ix],
          vy = velocities[iy],
          vz = velocities[iz];

        // mouse repulsion (in the z=0 plane)
        const dx = px - mx;
        const dy = py - my;
        const dz = pz;
        const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);
        if (dist < 1.5 && dist > 0.0001) {
          const force = (1.5 - dist) * 0.01;
          vx += (dx / dist) * force;
          vy += (dy / dist) * force;
          vz += (dz / dist) * force;
        }

        // spring back to original + damping
        vx += (original[ix] - px) * 0.001;
        vy += (original[iy] - py) * 0.001;
        vz += (original[iz] - pz) * 0.001;
        vx *= 0.95;
        vy *= 0.95;
        vz *= 0.95;

        positions[ix] = px + vx;
        positions[iy] = py + vy;
        positions[iz] = pz + vz;
        velocities[ix] = vx;
        velocities[iy] = vy;
        velocities[iz] = vz;
      }
      geometry.attributes.position.needsUpdate = true;
      points.rotation.y = t * 0.05;
      renderer.render(scene, camera);
    };

    const onResize = () => {
      const w = mount.clientWidth;
      const h = Math.max(mount.clientHeight, 1);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    };
    window.addEventListener("resize", onResize);

    // recolor on theme flip
    const themeObserver = new MutationObserver(paintColors);
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", paintColors);

    if (reduceMotion) {
      renderer.render(scene, camera); // single static frame, no loop / no mouse
    } else {
      window.addEventListener("mousemove", onMouseMove);
      const loop = () => {
        renderFrame();
        requestAnimationFrame(loop);
      };
      requestAnimationFrame(loop);
    }
  }
</script>
