---
import { nav } from "../data/nav";
---

{/* Desktop sticky strip — the horizontal link row that's been there. */}
<section class="nav-section">
  <nav class="nav" id="section-menu" aria-label="Sections">
    {nav.map((n) => <a class="nav-link" href={n.href}>{n.label}</a>)}
  </nav>
</section>

{/* Mobile-only fixed pill matching ThemeToggle exactly, with its own dropdown. */}
<button
  type="button"
  class="burger"
  aria-label="Open section menu"
  aria-expanded="false"
  aria-controls="mobile-menu"
>
  <svg class="b-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
  <svg class="b-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
</button>
<nav class="mobile-menu" id="mobile-menu" aria-label="Sections" data-open="false">
  {nav.map((n) => <a class="nav-link" href={n.href}>{n.label}</a>)}
</nav>

<script>
  const burger = document.querySelector<HTMLButtonElement>(".burger");
  const menu = document.querySelector<HTMLElement>(".mobile-menu");

  function setOpen(open: boolean) {
    if (!burger || !menu) return;
    burger.dataset.open = open ? "true" : "false";
    menu.dataset.open = open ? "true" : "false";
    burger.setAttribute("aria-expanded", open ? "true" : "false");
  }

  burger?.addEventListener("click", () => {
    setOpen(burger.dataset.open !== "true");
  });

  menu?.querySelectorAll<HTMLAnchorElement>("a").forEach((a) => {
    a.addEventListener("click", () => setOpen(false));
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && burger?.dataset.open === "true") setOpen(false);
  });

  document.addEventListener("click", (e) => {
    if (burger?.dataset.open !== "true") return;
    const target = e.target as Node;
    if (!burger.contains(target) && !menu?.contains(target)) setOpen(false);
  });
</script>

<style>
  .nav-section {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-cream) 86%, transparent);
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
    border-top: 1px solid var(--color-fog);
    border-bottom: 1px solid var(--color-fog);
    padding: 0.75rem 1rem;
  }
  .nav {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    justify-content: space-evenly;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-stone);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--color-terracotta);
    background: color-mix(in srgb, var(--color-terracotta) 12%, transparent);
    text-decoration: none;
  }

  /* Mobile burger — identical pill shape to ThemeToggle, mirrored top-left. */
  .burger {
    display: none; /* hidden on desktop; shown via media query below */
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 60;
    background: color-mix(in srgb, var(--color-cream) 80%, transparent);
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
    border: 1px solid var(--color-fog);
    color: var(--color-ink-soft);
    padding: 0.55rem;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    box-shadow: 0 4px 14px -6px rgba(0, 0, 0, 0.25);
  }
  .burger:hover {
    color: var(--color-terracotta);
    border-color: color-mix(in srgb, var(--color-terracotta) 50%, var(--color-fog));
    transform: translateY(-1px);
  }
  .burger :global(svg) {
    width: 18px;
    height: 18px;
  }
  .burger .b-close { display: none; }
  .burger[data-open="true"] .b-open { display: none; }
  .burger[data-open="true"] .b-close { display: inline-flex; }

  /* Mobile dropdown menu — fixed below the burger when open. */
  .mobile-menu {
    display: none;
    position: fixed;
    top: calc(1rem + 40px + 0.5rem); /* below the burger pill + gap */
    left: 1rem;
    right: 1rem;
    z-index: 59;
    flex-direction: column;
    align-items: stretch;
    padding: 0.5rem 0.75rem;
    background: color-mix(in srgb, var(--color-cream) 92%, transparent);
    backdrop-filter: blur(20px) saturate(120%);
    -webkit-backdrop-filter: blur(20px) saturate(120%);
    border: 1px solid var(--color-fog);
    border-radius: 0.75rem;
    box-shadow: 0 18px 36px -16px rgba(0, 0, 0, 0.45);
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: max-height 0.25s ease, opacity 0.15s ease;
  }
  .mobile-menu[data-open="true"] {
    max-height: 70vh;
    opacity: 1;
    pointer-events: auto;
  }
  .mobile-menu .nav-link {
    padding: 0.75rem 0.5rem;
    font-size: 1rem;
    border-bottom: 1px solid var(--color-fog);
  }
  .mobile-menu .nav-link:last-of-type { border-bottom: 0; }

  @media (max-width: 768px) {
    .nav-section { display: none; }
    .burger { display: inline-flex; }
    .mobile-menu { display: flex; }
  }
</style>
