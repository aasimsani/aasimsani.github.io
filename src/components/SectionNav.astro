---
import { nav } from "../data/nav";
---

<section class="nav-section d-flex justify-content-center">
  <div class="nav justify-content-evenly">
    {nav.map((n) => <a class="nav-link" href={n.href}>{n.label}</a>)}
    <button
      type="button"
      class="theme-toggle"
      aria-label="Toggle light/dark theme"
      title="Toggle theme"
    >
      <svg class="t-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      <svg class="t-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </div>
</section>

<script>
  function applyToggleState() {
    const explicit = document.documentElement.getAttribute("data-theme");
    const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const isDark = explicit ? explicit === "dark" : systemDark;
    document.querySelectorAll<HTMLButtonElement>(".theme-toggle").forEach((btn) => {
      btn.dataset.themeIs = isDark ? "dark" : "light";
    });
  }

  function toggleTheme() {
    const explicit = document.documentElement.getAttribute("data-theme");
    const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const isCurrentlyDark = explicit ? explicit === "dark" : systemDark;
    const next = isCurrentlyDark ? "light" : "dark";
    document.documentElement.setAttribute("data-theme", next);
    try {
      localStorage.setItem("theme", next);
    } catch (e) { /* localStorage blocked */ }
    applyToggleState();
  }

  document.querySelectorAll<HTMLButtonElement>(".theme-toggle").forEach((btn) => {
    btn.addEventListener("click", toggleTheme);
  });

  // Sync with system pref changes when user hasn't set an explicit theme.
  window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
    if (!document.documentElement.getAttribute("data-theme")) applyToggleState();
  });

  applyToggleState();
</script>

<style>
  .nav-section {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-cream) 86%, transparent);
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
    border-top: 1px solid var(--color-fog);
    border-bottom: 1px solid var(--color-fog);
    padding: 0.75rem 1rem;
  }
  .nav {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    justify-content: space-evenly;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-stone);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--color-terracotta);
    background: color-mix(in srgb, var(--color-terracotta) 12%, transparent);
    text-decoration: none;
  }
  .theme-toggle {
    background: transparent;
    border: 0;
    padding: 0.3rem 0.5rem;
    margin-left: 0.5rem;
    color: var(--color-stone);
    cursor: pointer;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .theme-toggle:hover {
    color: var(--color-terracotta);
    background: color-mix(in srgb, var(--color-terracotta) 10%, transparent);
  }
  .theme-toggle :global(svg) {
    width: 16px;
    height: 16px;
  }
  .theme-toggle .t-sun { display: none; }
  .theme-toggle .t-moon { display: inline-flex; }
  .theme-toggle[data-theme-is="dark"] .t-sun { display: inline-flex; }
  .theme-toggle[data-theme-is="dark"] .t-moon { display: none; }
</style>
