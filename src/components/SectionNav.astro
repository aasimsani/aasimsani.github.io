---
import { nav } from "../data/nav";
---

<section class="nav-section">
  <button
    type="button"
    class="burger"
    aria-label="Open section menu"
    aria-expanded="false"
    aria-controls="section-menu"
  >
    <svg class="b-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/></svg>
    <svg class="b-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
  </button>
  <nav class="nav" id="section-menu" aria-label="Sections">
    {nav.map((n) => <a class="nav-link" href={n.href}>{n.label}</a>)}
  </nav>
</section>

<script>
  const section = document.querySelector<HTMLElement>(".nav-section");
  const burger = document.querySelector<HTMLButtonElement>(".burger");
  const menu = document.querySelector<HTMLElement>("#section-menu");

  function setOpen(open: boolean) {
    if (!section || !burger) return;
    section.dataset.menuOpen = open ? "true" : "false";
    burger.setAttribute("aria-expanded", open ? "true" : "false");
  }

  burger?.addEventListener("click", () => {
    const isOpen = section?.dataset.menuOpen === "true";
    setOpen(!isOpen);
  });

  // Close the menu when a link is tapped.
  menu?.querySelectorAll<HTMLAnchorElement>("a").forEach((a) => {
    a.addEventListener("click", () => setOpen(false));
  });

  // Close on Escape.
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && section?.dataset.menuOpen === "true") setOpen(false);
  });
</script>

<style>
  .nav-section {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-cream) 86%, transparent);
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
    border-top: 1px solid var(--color-fog);
    border-bottom: 1px solid var(--color-fog);
    padding: 0.75rem 1rem;
  }
  .nav {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    justify-content: space-evenly;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-stone);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--color-terracotta);
    background: color-mix(in srgb, var(--color-terracotta) 12%, transparent);
    text-decoration: none;
  }

  /* Burger button — hidden on desktop, shown on mobile. */
  .burger {
    display: none;
    background: transparent;
    border: 0;
    padding: 0.35rem 0.6rem;
    color: var(--color-ink-soft);
    cursor: pointer;
    border-radius: 4px;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .burger:hover {
    color: var(--color-terracotta);
    background: color-mix(in srgb, var(--color-terracotta) 10%, transparent);
  }
  .burger :global(svg) {
    width: 22px;
    height: 22px;
    transition: opacity 0.15s ease;
  }
  .burger .b-close { display: none; }
  .nav-section[data-menu-open="true"] .burger .b-open { display: none; }
  .nav-section[data-menu-open="true"] .burger .b-close { display: inline-flex; }

  @media (max-width: 768px) {
    .nav-section {
      padding: 0.5rem 1rem;
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }
    .burger {
      display: inline-flex;
    }
    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      gap: 0;
      padding: 0.75rem 1rem 1rem;
      background: color-mix(in srgb, var(--color-cream) 96%, transparent);
      backdrop-filter: blur(20px) saturate(120%);
      -webkit-backdrop-filter: blur(20px) saturate(120%);
      border-bottom: 1px solid var(--color-fog);
      box-shadow: 0 12px 28px -16px rgba(0, 0, 0, 0.35);
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition: max-height 0.25s ease, opacity 0.15s ease;
    }
    .nav-section[data-menu-open="true"] .nav {
      max-height: 70vh;
      opacity: 1;
      pointer-events: auto;
    }
    .nav-link {
      padding: 0.75rem 0.5rem;
      font-size: 1rem;
      border-bottom: 1px solid var(--color-fog);
    }
    .nav-link:last-of-type { border-bottom: 0; }
  }
</style>
