---
import { education } from "../data/education";
import SectionHeader from "./SectionHeader.astro";
---

<section class="education section-anchor" id="education">
  <div class="container">
    <SectionHeader title="Education" glyph="graduation" />
    <div class="entries">
      {education.map((s) => (
        <article class="entry">
          <a class="logo-mark" data-mat={s.mat} href={s.link} target="_blank" rel="noopener">
            <img src={s.logo} alt={s.school} />
          </a>
          <div class="body">
            <h3>{s.school}</h3>
            <p set:html={s.description}></p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .education {
    padding: 5rem 1.5rem;
    background: var(--color-cream);
  }
  .container {
    max-width: 760px;
    margin: 0 auto;
  }
  .entries {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .entry {
    display: grid;
    grid-template-columns: 108px 1fr;
    gap: 1.75rem;
    align-items: start;
  }
  @media (max-width: 600px) {
    .entry { grid-template-columns: 1fr; }
  }
  h3 {
    font-size: 1.45rem;
    font-weight: 500;
    margin: 0 0 0.75rem;
  }
  p {
    font-size: 1.05rem;
    margin: 0;
  }
</style>
